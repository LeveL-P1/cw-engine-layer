# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/whiteboard_dev"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_EXPIRES_IN="12h"

# OAuth - Google
OAUTH_GOOGLE_CLIENT_ID="your-google-oauth-client-id"
OAUTH_GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# Email Configuration (for verification & password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-specific-password"
SMTP_FROM_EMAIL="noreply@whiteboard-app.com"
SMTP_FROM_NAME="Whiteboard App"

# Application Settings
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"

# Logging
LOG_LEVEL="debug"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"
AUTH_RATE_LIMIT_MAX_REQUESTS="5"

# Security
CORS_ORIGIN="http://localhost:3000"
ALLOW_INSECURE_HTTP="true"

# Optional: Error Tracking (Sentry)
# SENTRY_DSN="https://your-sentry-dsn"
