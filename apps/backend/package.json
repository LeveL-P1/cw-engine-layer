    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "20.19.39",
    "@types/ws": "8.18.1",
    "prisma": "6.19.3",
    "rimraf": "6.0.1",
    "ts-node-dev": "2.0.0",
    "typescript": "5.9.3"
  }
