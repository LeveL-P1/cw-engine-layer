{
  "name": "cw-engine",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "cd apps/backend && npm run dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "lint:frontend": "cd apps/frontend && npm run lint",
    "typecheck:frontend": "cd apps/frontend && npm run typecheck",
    "typecheck:backend": "cd apps/backend && npm run typecheck",
    "build:frontend": "cd apps/frontend && npm run build",
    "build:backend": "cd apps/backend && npm run build",
    "prisma:validate": "cd apps/backend && npx prisma validate",
    "prisma:generate": "cd apps/backend && npx prisma generate",
    "prisma:migrate:deploy": "cd apps/backend && npx prisma migrate deploy",
    "install:all": "cd apps/backend && npm install && cd ../frontend && npm install"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
